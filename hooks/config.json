{
  "_comment": "Copy the 'hooks' section for your OS into ~/.claude/settings.json.",

  "windows": {
    "_requires": "powershell.exe (included in Windows)",
    "_script": "notify-windows.sh",
    "_events": "Stop + Notification + PostToolUseFailure",
    "hooks": {
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-windows.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "Notification": [
        {
          "matcher": "idle_prompt|permission_prompt",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-windows.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "PostToolUseFailure": [
        {
          "matcher": "*",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-windows.sh",
              "timeout": 5
            }
          ]
        }
      ]
    }
  },

  "macos": {
    "_requires": "osascript (included in macOS)",
    "_script": "notify-mac.sh",
    "_events": "Stop + Notification + PostToolUseFailure",
    "hooks": {
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-mac.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "Notification": [
        {
          "matcher": "idle_prompt|permission_prompt",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-mac.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "PostToolUseFailure": [
        {
          "matcher": "*",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-mac.sh",
              "timeout": 5
            }
          ]
        }
      ]
    }
  },

  "linux": {
    "_requires": "libnotify (notify-send)",
    "_script": "notify-linux.sh",
    "_events": "Stop + Notification + PostToolUseFailure",
    "hooks": {
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-linux.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "Notification": [
        {
          "matcher": "idle_prompt|permission_prompt",
          "hooks": [
            {
              "type": "command",
